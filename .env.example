# Nexus — environment configuration
#
# The app runs fully WITHOUT any of these (deterministic offline fallback:
# BM25 + entity retrieval, extractive answers, rule-based RCA/compliance).
# Add a Gemini key to turn on LLM synthesis, agentic reasoning, embeddings and
# multimodal P&ID vision.

# Option A — Gemini (recommended; enables vision). https://aistudio.google.com
GEMINI_API_KEY=
Nexus_MODEL=gemini-2.5-flash

# Session-token signing secret (HMAC-SHA256). Random 256-bit value.
AUTH_SECRET=

# Option B — Vercel AI Gateway (text + embeddings; no vision).
# AI_GATEWAY_API_KEY=
# Nexus_GATEWAY_MODEL=google/gemini-2.5-flash
